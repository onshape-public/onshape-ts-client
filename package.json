{
  "name": "onshape-ts-client",
  "version": "1.2.0",
  "type": "module",
  "description": "Examples of Onshape APIs in typescript",
  "scripts": {
    "build": "npm install && tsc",
    "cleanoutputdirectory": "rimraf ./output && rimraf ./exports && rimraf ./reports && rimraf logs",
    "processfolder": "node .compiledjs/folder.js",
    "findrevisions": "node .compiledjs/revisions.js",
    "findworkflows": "node .compiledjs/workflows.js",
    "createrevision": "node .compiledjs/createrev.js",
    "revisionexport": "node .compiledjs/revisionexport.js",
    "webhook": "node .compiledjs/webhook.js",
    "lint": "eslint .",
    "test": "./test/testscript.bash"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ptrajkumar/onshape-ts-client.git"
  },
  "author": "ptrajkumar",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/ptrajkumar/onshape-ts-client/issues"
  },
  "homepage": "https://github.com/ptrajkumar/onshape-ts-client#readme",
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "csv-stringify": "^6.4.6",
    "death": "^1.1.0",
    "debug": "^4.3.4",
    "express": "^5.2.1",
    "log4js": "^6.9.1",
    "minimist": "^1.2.8",
    "mkdirp": "^3.0.1",
    "randomstring": "^1.3.0",
    "rimraf": "^6.1.3",
    "sanitize-filename": "^1.6.3",
    "time-span": "^5.1.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/body-parser": "^1.19.5",
    "@types/death": "^1.1.5",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/minimist": "^1.2.5",
    "@types/mkdirp": "^1.0.2",
    "@types/node": "^26.0.1",
    "@types/randomstring": "^1.3.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  }
}
