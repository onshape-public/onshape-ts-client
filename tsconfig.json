{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["es2024"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": ".compiledjs",
    "sourceMap": true,
    "removeComments": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "strict": true,
    "strictNullChecks": false
  },
  "include": [
    "*.ts",
    "./utils/*.ts",
    "./decl/*.d.ts"
  ],
  "exclude": [
    "./node_modules"
  ]
}
